# =============================================================
# Go Diego Travel Agency — Environment Variables
# =============================================================
# Copia este archivo a .env y reemplaza los valores.
# NUNCA commitear el archivo .env real.
# =============================================================

# ——— PostgreSQL ———
POSTGRES_DB=travel_agency
POSTGRES_USER=travel_agency_user
POSTGRES_PASSWORD=tu_password_postgres
POSTGRES_PORT=5432

# ——— Redis ———
REDIS_HOST=localhost
REDIS_PORT=6379

# ——— Adminer ———
ADMINER_PORT=18080

# ——— Observability ———
PROMETHEUS_PORT=9090
LOKI_PORT=3100
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me
UPTIME_KUMA_PORT=3001

# ——— n8n ———
N8N_PORT=5678
N8N_WEBHOOK_URL=http://localhost:5678/
BACKEND_URL=http://backend:8080
AGENT_URL=http://agent:3000

# ——— Backend Spring API ———
SERVER_PORT=8080
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/travel_agency
SPRING_DATASOURCE_USERNAME=travel_agency_user
SPRING_DATASOURCE_PASSWORD=tu_password_postgres
SPRING_DATA_REDIS_HOST=localhost
SPRING_DATA_REDIS_PORT=6379
SPRING_DATA_REDIS_TIMEOUT=2s
RAG_CHAT_REDIS_TTL_HOURS=24
RAG_SERVICE_URL=http://127.0.0.1:3000
RAG_API_KEY=genera_una_clave_aleatoria_de_32_chars
SPRING_JPA_SHOW_SQL=false
SPRING_FLYWAY_BASELINE_ON_MIGRATE=true
SPRING_FLYWAY_BASELINE_VERSION=0

# ——— Agent (TypeScript) ———
GOOGLE_API_KEY=tu_google_api_key_aqui

# ——— Frontend ———
FRONTEND_PORT=4321
INTERNAL_API_URL=http://backend:8080
PUBLIC_API_URL=http://localhost:8080
PUBLIC_WHATSAPP_NUMBER=+521XXXXXXXXXX
PUBLIC_SITE_URL=http://localhost:4321
ADMIN_DASHBOARD_PASSWORD=change_me
