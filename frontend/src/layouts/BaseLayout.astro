---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Go Diego - Agencia de viajes con paquetes todo incluido, cruceros y viajes a la medida. Tu proxima aventura comienza aqui." } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>✈️</text></svg>" />
    <title>{title}</title>
  </head>
  <body class="bg-light text-dark min-h-screen flex flex-col">
    <header class="bg-white shadow-sm sticky top-0 z-50">
      <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
        <a href="/" class="text-2xl font-bold text-primary">Go Diego</a>
        <div class="hidden md:flex items-center gap-6">
          <a href="/" class="text-gray-600 hover:text-primary transition">Inicio</a>
          <a href="/#viajes" class="text-gray-600 hover:text-primary transition">Viajes</a>
          <a href="/#servicios" class="text-gray-600 hover:text-primary transition">Servicios</a>
          <a href="/#contacto" class="text-gray-600 hover:text-primary transition">Contacto</a>
          <a href="/admin/dashboard" class="bg-dark text-white px-4 py-2 rounded-lg hover:bg-gray-700 transition text-sm">Dashboard</a>
        </div>
        <button id="mobile-menu-btn" class="md:hidden text-gray-600" aria-label="Menu">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
        </button>
      </nav>
      <div id="mobile-menu" class="hidden md:hidden bg-white border-t px-4 py-3 space-y-2">
        <a href="/" class="block text-gray-600 hover:text-primary py-2">Inicio</a>
        <a href="/#viajes" class="block text-gray-600 hover:text-primary py-2">Viajes</a>
        <a href="/#servicios" class="block text-gray-600 hover:text-primary py-2">Servicios</a>
        <a href="/#contacto" class="block text-gray-600 hover:text-primary py-2">Contacto</a>
        <a href="/admin/dashboard" class="block bg-dark text-white px-4 py-2 rounded-lg text-center text-sm">Dashboard</a>
      </div>
    </header>

    <main class="flex-1">
      <slot />
    </main>

    <footer id="contacto" class="bg-dark text-gray-300 mt-auto">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <div>
            <h3 class="text-xl font-bold text-white mb-4">Go Diego</h3>
            <p class="text-gray-400">Tu agencia de viajes de confianza. Paquetes todo incluido, cruceros y viajes a la medida.</p>
          </div>
          <div>
            <h3 class="text-lg font-semibold text-white mb-4">Contacto</h3>
            <ul class="space-y-2 text-gray-400">
              <li>WhatsApp: +52 1 XXX XXX XXXX</li>
              <li>Email: info@godiego.com</li>
              <li>Horario: Lun-Vie 9:00-18:00</li>
            </ul>
          </div>
          <div>
            <h3 class="text-lg font-semibold text-white mb-4">Servicios</h3>
            <ul class="space-y-2 text-gray-400">
              <li>Paquetes Todo Incluido</li>
              <li>Cruceros</li>
              <li>Viajes a la Medida</li>
            </ul>
          </div>
        </div>
        <div class="border-t border-gray-700 mt-8 pt-8 text-center text-gray-500 text-sm">
          <p>&copy; {new Date().getFullYear()} Go Diego. Todos los derechos reservados.</p>
        </div>
      </div>
    </footer>

    <script>
      const btn = document.getElementById('mobile-menu-btn');
      const menu = document.getElementById('mobile-menu');
      btn?.addEventListener('click', () => {
        menu?.classList.toggle('hidden');
      });
    </script>
  </body>
</html>
